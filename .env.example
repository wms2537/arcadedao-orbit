# Deployer private key (with 0x prefix)
DEPLOYER_PRIVATE_KEY=0x...

# Separate keys for batch poster and validator (recommended for production)
# If not set, DEPLOYER_PRIVATE_KEY is used for both
# BATCH_POSTER_PRIVATE_KEY=0x...
# VALIDATOR_PRIVATE_KEY=0x...

# Parent chain RPC URL (Arbitrum Sepolia)
PARENT_CHAIN_RPC=https://sepolia-rollup.arbitrum.io/rpc

# Orbit chain RPC (after node is running)
ORBIT_CHAIN_RPC=http://localhost:8449

# Chain configuration
CHAIN_ID=942070
CHAIN_NAME=ArcadeDao

# ARCADE token address on Arbitrum Sepolia (set after deploying the token)
ARCADE_TOKEN_ADDRESS=

# DAS (Data Availability Server) — required for AnyTrust chains
DAS_SERVER_URL=http://localhost:9877
